VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
# Production attachment pipeline. The private worker receives the service role
# and polls the durable attachment_processing_jobs queue; these values are not
# exposed to the browser.
ATTACHMENT_SCANNER_DEV_BYPASS=false
ATTACHMENT_WORKER_POLL_SECONDS=2
ATTACHMENT_WORKER_MAX_ATTEMPTS=4
ATTACHMENT_OPENROUTER_MODEL=google/gemini-2.5-flash
